@model IList<TodoListApp.WebApp.Models.TodoItemWebApiModel>
@{
    ViewData["Title"] = "Tasks by Tag";
    var tag = ViewData["Tag"] as TodoListApp.WebApp.Models.TagWebApiModel;
}

<h2>Tasks tagged with &quot;@tag?.Name&quot;</h2>

@if (Model.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Due Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsOverdue ? "table-danger" : "")">
                    <td>@item.Title</td>
                    <td class="@(item.IsOverdue ? "text-danger fw-bold" : "")">@(item.DueDate?.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture) ?? "-")</td>
                    <td>@(item.Status switch { 0 => "Not Started", 1 => "In Progress", _ => "Completed" })</td>
                    <td>
                        <a asp-controller="TodoItem" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No tasks with this tag.</p>
}

<p><a asp-action="Index" class="btn btn-secondary">Back to Tags</a></p>
