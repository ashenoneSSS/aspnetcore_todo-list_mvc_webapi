@model TodoListApp.WebApp.Models.TodoItemWebApiModel
@{
    ViewData["Title"] = "Update Task Status";
}

<h2>Update Task Status</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TodoListId" />
    <input type="hidden" asp-for="CreatedDate" />
    <input type="hidden" asp-for="Title" />
    <input type="hidden" asp-for="Description" />
    <input type="hidden" asp-for="DueDate" />
    <input type="hidden" asp-for="CreatorId" />
    <input type="hidden" asp-for="AssigneeId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label" for="@Html.IdFor(m => m.Status)">Status</label>
        <select asp-for="Status" id="@Html.IdFor(m => m.Status)" class="form-select">
            <option value="0">Not Started</option>
            <option value="1">In Progress</option>
            <option value="2">Completed</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="AssignedTasks" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

