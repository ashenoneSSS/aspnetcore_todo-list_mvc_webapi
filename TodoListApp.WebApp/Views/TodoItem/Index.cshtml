@model IList<TodoListApp.WebApp.Models.TodoItemWebApiModel>
@{
    ViewData["Title"] = "Tasks";
    var list = ViewData["TodoList"] as TodoListApp.WebApp.Models.TodoListWebApiModel;
}

<h2>Tasks: @list?.Title</h2>

<p>
    <a asp-action="Create" asp-route-listId="@list?.Id" class="btn btn-primary">Add Task</a>
    <a asp-controller="TodoList" asp-action="Index" class="btn btn-secondary">Back to Lists</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Due Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var statusClass = item.Status switch
            {
                0 => "task-status-notstarted",
                1 => "task-status-inprogress",
                _ => "task-status-completed",
            };

            <tr class="@statusClass">
                <td>@item.Title</td>
                <td>@(item.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td>@(item.Status switch { 0 => "Not Started", 1 => "In Progress", _ => "Completed" })</td>
                <td>
                    <div class="list-actions">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
