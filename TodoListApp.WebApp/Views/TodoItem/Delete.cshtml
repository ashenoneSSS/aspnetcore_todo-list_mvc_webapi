@model TodoListApp.WebApp.Models.TodoItemWebApiModel
@{
    ViewData["Title"] = "Delete Task";
}

<h2>Delete Task</h2>

<h4>Are you sure you want to delete this task?</h4>
<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Due Date</dt>
    <dd class="col-sm-10">@(Model.DueDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="listId" value="@Model.TodoListId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" asp-route-listId="@Model.TodoListId" class="btn btn-secondary">Cancel</a>
</form>
