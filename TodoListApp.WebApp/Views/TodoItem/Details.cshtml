@model TodoListApp.WebApp.Models.TodoItemWebApiModel
@{
    ViewData["Title"] = "Task Details";
}

<h2>Task Details</h2>

<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Due Date</dt>
    <dd class="col-sm-10 @(Model.IsOverdue ? "text-danger" : "")">@(Model.DueDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@(Model.Status switch { 0 => "Not Started", 1 => "In Progress", _ => "Completed" })</dd>
    <dt class="col-sm-2">Assignee</dt>
    <dd class="col-sm-10">@Model.AssigneeId</dd>
    @if (Model.Tags?.Count > 0)
    {
        <dt class="col-sm-2">Tags</dt>
        <dd class="col-sm-10">
            @foreach (var tag in Model.Tags)
            {
                <a asp-controller="Tags" asp-action="Tasks" asp-route-id="@tag.Id" class="badge bg-secondary text-decoration-none me-1">@tag.Name</a>
            }
        </dd>
    }
</dl>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index" asp-route-listId="@Model.TodoListId" class="btn btn-secondary">Back to List</a>
</p>
