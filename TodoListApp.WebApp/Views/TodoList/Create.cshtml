@model TodoListApp.WebApp.Models.TodoListWebApiModel
@{
    ViewData["Title"] = "Create Todo List";
}

<h2>Create Todo List</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Title" class="form-label" for="@Html.IdFor(m => m.Title)">Title</label>
        <input asp-for="Title" class="form-control" id="@Html.IdFor(m => m.Title)" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label" for="@Html.IdFor(m => m.Description)">Description</label>
        <textarea asp-for="Description" id="@Html.IdFor(m => m.Description)" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
