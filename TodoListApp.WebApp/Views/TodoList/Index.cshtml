@model IList<TodoListApp.WebApp.Models.TodoListWebApiModel>
@{
    ViewData["Title"] = "My Todo Lists";
}

<h2>My Todo Lists</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add new</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var list in Model)
        {
            <tr>
                <td>@list.Title</td>
                <td>@list.Description</td>
                <td>
                    <div class="list-actions">
                        @if (list.Id == -1)
                        {
                            <a asp-controller="AssignedTasks" asp-action="Index" class="btn btn-sm btn-outline-primary">Tasks</a>
                            <span class="btn btn-sm btn-outline-secondary disabled" aria-disabled="true">Edit</span>
                            <span class="btn btn-sm btn-outline-danger disabled" aria-disabled="true">Delete</span>
                        }
                        else
                        {
                            <a asp-controller="TodoItem" asp-action="Index" asp-route-listId="@list.Id" class="btn btn-sm btn-outline-primary">Tasks</a>
                            <a asp-action="Edit" asp-route-id="@list.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@list.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
